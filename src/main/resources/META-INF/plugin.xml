<idea-plugin>
    <id>com.github.ryanxie0827.versiondraft</id>
    <name>Version-Draft</name>
    <vendor>ryanxie0827</vendor>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="Version Draft"
                    anchor="right"
                    icon="/icons/draft_sidebar.svg"
                    factoryClass="com.github.ryanxie0827.versiondraft.ui.DraftToolWindowFactory"/>
    </extensions>

    <actions>
        <action id="VersionDraft.OpenDraftAction"
                class="com.github.ryanxie0827.versiondraft.actions.OpenDraftAction"
                text="Open Version Draft"
                description="快速记录发版变更">
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt N"/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>

        <action id="VersionDraft.SearchDraftAction"
                class="com.github.ryanxie0827.versiondraft.actions.SearchDraftAction"
                text="Search Version Draft"
                description="搜索历史发版记录">
            <keyboard-shortcut keymap="$default" first-keystroke="ctrl alt H"/>
            <add-to-group group-id="ToolsMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>